{
  "manifest_version": 3,
  "name": "DeepSeek Price Clock",
  "version": "1.1.1",
  "description": "Shows whether DeepSeek API pricing is at normal price or 2× peak price based on Philippines time (UTC+8).",
  "browser_specific_settings": {
    "gecko": {
      "id": "deepseek-price-clock@zenabus.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "icons": {
    "16": "icons/icon16.svg",
    "32": "icons/icon32.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "action": {
    "default_title": "DeepSeek Price Clock",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "32": "icons/icon32.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://api.deepseek.com/"
  ]
}